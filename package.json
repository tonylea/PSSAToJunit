{
  "name": "pssatojunit",
  "version": "0.0.16",
  "description": "Convert PSScriptAnalyzer results to Junit XML",
  "private": "true",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tonylea/PSSAToJunit.git"
  },
  "manifestProperties": {
    "guid": "fa5b675c-f181-4571-bda8-2b24da71d04b",
    "compatiblePSEditions": [
      "Core"
    ],
    "author": "Tony Lea",
    "companyName": "",
    "copyright": "(c) Tony Lea. All rights reserved.",
    "powerShellVersion": "7.0.0",
    "requiredModules": [
      "PSScriptAnalyzer"
    ],
    "tags": [
      "PSSA",
      "PSScriptAnalyzer",
      "Junit",
      "PSEdition_Core",
      "Windows",
      "Linux",
      "MacOS"
    ],
    "licenseUri": "https://mit-license.org",
    "projectUri": "https://github.com/tonylea/PSSAToJunit"
  },
  "devDependencies": {
    "@commitlint/cli": "20.4.3",
    "@commitlint/config-conventional": "20.4.3",
    "@secretlint/secretlint-rule-azure": "^11.3.1",
    "@secretlint/secretlint-rule-pattern": "^11.3.1",
    "@secretlint/secretlint-rule-preset-recommend": "^11.3.1",
    "@secretlint/secretlint-rule-privatekey": "^11.3.1",
    "commit-and-tag-version": "^12.6.1",
    "git-cz": "^4.9.0",
    "husky": "^9.1.7",
    "markdown-link-check": "^3.14.2",
    "markdownlint-cli2": "^0.21.0",
    "markdownlint-cli2-formatter-junit": "^0.0.14",
    "mega-linter-runner": "^9.4.0",
    "npm-check-updates": "^19.6.3",
    "secretlint": "^11.3.1"
  },
  "scripts": {
    "prepare": "husky",
    "release": "commit-and-tag-version",
    "upgrade": "ncu -u && npm install",
    "update": "npm run upgrade",
    "version-bump": "npm run release -- --skip.commit --skip.tag",
    "commit": "git-cz",
    "markdown-link-check": "markdown-link-check --config ./.markdown-link-check.json",
    "secretlint": "secretlint '**/*'",
    "megalinter": "mega-linter-runner --path ./ --flavor documentation --release v9.4.0 --fix --remove-container"
  }
}
